# flynerd-agency Environment Variables Example
# Copy this to .env and fill in your keys

# --- DATABASE (Supabase) ---
# Replace [PASSWORD] with your Supabase database password
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres"

# --- AI & LLM (Groq) ---
GROQ_API_KEY="gsk_xxxx"

# --- CRM & EMAIL (ActiveCampaign) ---
# Found in Settings > Developer
ACTIVECAMPAIGN_URL="https://youraccount.api-us1.com"
ACTIVECAMPAIGN_KEY="xxxx"

# --- SCOUTING (Yelp Fusion) ---
YELP_API_KEY="xxxx"

# --- VIDEO GENERATION (HeyGen) ---
HEYGEN_API_KEY="xxxx"

# --- PAYMENTS (Stripe) ---
# Use your test mode link first
STRIPE_PAYMENT_LINK="https://buy.stripe.com/test_xxxx"

# --- VERCEL (Optional for deployment automation) ---
VERCEL_API_TOKEN="xxxx"

# --- TESTING ---
HEYGEN_MOCK_MODE=false

